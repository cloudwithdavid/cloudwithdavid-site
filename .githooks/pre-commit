#!/usr/bin/env bash
set -euo pipefail

if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "scripts/bump-asset-version.ps1"
elif command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "scripts/bump-asset-version.ps1"
else
  echo "PowerShell is required to run scripts/bump-asset-version.ps1" >&2
  exit 1
fi

git add index.html
